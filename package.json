{
  "name": "sellauth-discord-bot",
  "version": "1.0.0",
  "description": "Production-ready Discord bot integrating with the SellAuth API (vouches, purchases, automation, channel cleanup).",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "deploy": "node deploy-commands.js",
    "deploy:live": "node deploy-commands.js --live",
    "deploy:all": "node deploy-commands.js --all",
    "clear:global": "node deploy-commands.js --clear --global",
    "dev": "node --watch index.js"
  },
  "keywords": [
    "discord",
    "discord.js",
    "sellauth",
    "bot"
  ],
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7"
  }
}
