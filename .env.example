# ─────────────────────────────────────────────────────────────
#  Discord credentials (from https://discord.com/developers/applications)
# ─────────────────────────────────────────────────────────────
# Your bot's token — KEEP THIS SECRET. Reset it if it ever leaks.
DISCORD_TOKEN=your-bot-token-here
# The Application ID (a.k.a. Client ID) of your bot.
DISCORD_CLIENT_ID=your-application-id-here
# OAuth2 client secret (only needed if you add OAuth flows; safe to leave blank).
DISCORD_CLIENT_SECRET=your-client-secret-here

# Test guild — `npm run deploy` registers commands here instantly.
# Leave blank to register globally (can take up to 1 hour to appear).
DISCORD_GUILD_ID=
# Live/production guild — `npm run deploy:live` targets this one.
DISCORD_LIVE_GUILD_ID=

# ─────────────────────────────────────────────────────────────
#  SellAuth API
# ─────────────────────────────────────────────────────────────
# Base URL for the SellAuth API. Change only if SellAuth tells you to.
SELLAUTH_API_BASE=https://api.sellauth.com/v1
# Default API key (Bearer token) used as a fallback when a guild has not set
# one via /setapikey. You can leave this blank and configure per-guild instead.
SELLAUTH_API_KEY=
# Your SellAuth Shop ID. Required by most SellAuth endpoints.
SELLAUTH_SHOP_ID=

# ─────────────────────────────────────────────────────────────
#  Security
# ─────────────────────────────────────────────────────────────
# 32-byte (64 hex char) key used to encrypt API keys stored in the database.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-hex-characters

# ─────────────────────────────────────────────────────────────
#  Bot behaviour
# ─────────────────────────────────────────────────────────────
# How often (in seconds) automation polls SellAuth for new vouches/purchases.
POLL_INTERVAL_SECONDS=120
# Default per-command cooldown in seconds.
COMMAND_COOLDOWN_SECONDS=3
# How often (in seconds) the bot rotates through its statuses (min 15).
STATUS_ROTATE_SECONDS=30
# Logging level: debug | info | warn | error
LOG_LEVEL=info
# Auto-register slash commands when the bot is added to a new server (so adding
# more servers needs no manual deploy). Set to false if you register globally
# (deploy-commands.js --global) to avoid commands showing up twice.
AUTO_REGISTER_ON_JOIN=true
